# ---------------------------------------------------------------------------
# Local development environment
# ---------------------------------------------------------------------------
# Phase 1 uses SQLite for zero-config local development. The Prisma schema is
# written to be PostgreSQL-compatible (no SQLite-only features, no enums), so
# moving to Postgres later is just:
#   1. set provider = "postgresql" in prisma/schema.prisma
#   2. point DATABASE_URL at your Postgres instance, e.g.
#      DATABASE_URL="postgresql://user:pass@localhost:5432/resistance?schema=public"
DATABASE_URL="file:./dev.db"

# Local file storage directory (relative to project root). See src/lib/storage.ts.
UPLOADS_DIR="uploads"
