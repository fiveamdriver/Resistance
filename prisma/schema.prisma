// =============================================================================
// Resistance — Phase 1 data model
// =============================================================================
// Local dev uses SQLite for zero-config setup. The schema is intentionally
// PostgreSQL-compatible: no enums (status/type fields are validated strings via
// src/lib/fileTypes.ts), no SQLite-only types. To move to Postgres, change the
// datasource provider to "postgresql" and update DATABASE_URL.
//
// Relationship overview (Phase 1):
//   User      1──*  Project
//   Project   1──*  ProjectFile
//   Project   1──*  Component
//   Project   1──*  Net
//   Project   1──*  BomItem
//   Project   1──*  DocumentChunk
//   Component 1──*  Pin
//   Pin       1──1  Connection   (a pin connects to exactly one net)
//   Net       1──*  Connection   (a net has many connections / pins)
//   BomItem   *──*  Component    (a BOM row can reference one or more components)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Optional owner. Nullable in Phase 1 because we don't have auth yet.
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  // JSON blob written by the KiCad MCP server's sync_to_resistance tool:
  // { syncedAt, boardMtime, kicadVersion }. String because Prisma's SQLite
  // connector has no Json type.
  syncMeta String?

  // Linked EDA project folder for in-app import/sync (desktop Phase 4).
  // Absolute path on the local machine; null = not linked.
  kicadProjectPath String?
  // Re-export netlist/BOM automatically when design files in the linked
  // folder change (file watcher, src/server/services/watcher-service.ts).
  autoSyncEnabled  Boolean @default(false)

  files          ProjectFile[]
  components      Component[]
  nets           Net[]
  bomItems       BomItem[]
  documentChunks DocumentChunk[]
  reviewRuns     ReviewRun[]
  board          Board?

  @@index([ownerId])
}

/// A file uploaded to a project (netlist, BOM, PDF, doc, etc.).
model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String
  originalName String // filename as uploaded by the user
  storedName   String // unique name on disk (collision-safe)
  path         String // path on disk relative to the uploads dir
  fileType     String // mime-ish / extension category — see lib/fileTypes.ts
  category     String // "netlist" | "bom" | "pdf" | "document" | "other"
  sizeBytes    Int      @default(0)
  // Parse lifecycle: "pending" | "parsed" | "failed"
  parseStatus  String   @default("pending")
  parseError   String?
  // Where the document came from: "upload" (human) | "design_link" (Datasheet
  // URL from the KiCad symbol) | "web_fetch" (found by the spec-fetch search).
  provenance   String   @default("upload")
  // Original URL for design_link / web_fetch documents.
  sourceUrl    String?
  // Verification gate result: "verified" (searchable) | "quarantined" (stored
  // but never indexed; awaiting one-click human approval).
  verifyStatus String   @default("verified")
  // sha256 of file bytes; dedupes datasheets across projects (DatasheetLibrary).
  contentHash  String?
  // MPN this document describes (datasheets). Drives the one-live-doc-per-
  // (project, mpn) dedupe rule and the coverage metric.
  mpn          String?
  uploadedAt   DateTime @default(now())

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentChunks DocumentChunk[]
  bomItems       BomItem[]

  @@index([projectId])
}

/// An electrical component (IC, resistor, connector, ...). RefDes e.g. "U7".
model Component {
  id          String  @id @default(cuid())
  projectId   String
  refDes      String // reference designator, e.g. "U7", "R12", "J1"
  name        String? // device / part name
  description String?
  value       String? // e.g. "10k", "100nF"
  footprint   String?
  mpn         String? // manufacturer part number; populated from KiCad fields or BOM
  // Datasheet URL from the design (KiCad symbol "Datasheet" property), carried
  // through the MCP sync BOM CSV. Drives tier-2 (design_link) ingestion.
  datasheetUrl String?

  // Physical placement from the .kicad_pcb layout (src/lib/parsers/kicadPcbParser.ts).
  // Null until a board is parsed; written independently of the netlist upsert so
  // the two parses never clobber each other. Millimeters, KiCad board coordinates.
  posX     Float?
  posY     Float?
  rotation Float? // degrees
  layer    String? // "F.Cu" (top) | "B.Cu" (bottom)

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pins     Pin[]
  bomItems BomItem[] // many-to-many: a component may appear on BOM rows

  @@unique([projectId, refDes])
  @@index([projectId])
  @@index([mpn])
}

/// Board-level layout facts extracted from the .kicad_pcb (one per project).
/// Derived, regenerated on every sync — safe to overwrite.
model Board {
  id           String   @id @default(cuid())
  projectId    String   @unique
  widthMm      Float? // bounding box of the Edge.Cuts outline
  heightMm     Float?
  layerCount   Int? // number of copper (*.Cu) layers
  copperLayers String   @default("[]") // JSON string[] of copper layer names, in stackup order
  zones        String   @default("[]") // JSON [{ netName, layer }] of copper pours
  sourceFile   String? // basename of the parsed .kicad_pcb
  parsedAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// An electrical net (signal). Name e.g. "5V", "GND", "SPI_CLK".
model Net {
  id        String @id @default(cuid())
  projectId String
  name      String

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connections Connection[]

  @@unique([projectId, name])
  @@index([projectId])
}

/// A pin on a component, e.g. U7 pin 14. Connects to at most one net.
model Pin {
  id          String  @id @default(cuid())
  componentId String
  number      String // pin number/designator, e.g. "14", "A1"
  name        String? // pin function name, e.g. "VCC", "GPIO3"

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  // One pin connects to exactly one net via a single Connection (enforced by
  // the unique pinId on Connection below).
  connection Connection?

  @@unique([componentId, number])
  @@index([componentId])
}

/// An edge in the connectivity graph: a single pin joined to a single net.
/// A net has many connections (one per pin on the net).
model Connection {
  id    String @id @default(cuid())
  netId String
  pinId String @unique // a pin appears in at most one connection

  net Net @relation(fields: [netId], references: [id], onDelete: Cascade)
  pin Pin @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@index([netId])
}

/// A row from a Bill of Materials. May map to one or more components.
model BomItem {
  id           String  @id @default(cuid())
  projectId    String
  // Source BOM file (audit #3: overlapping BOM sources). Each file owns its
  // rows — a re-parse supersedes only rows with the same fileId, and deleting
  // the file cascades its rows away. Null on legacy rows; the next parse of a
  // matching refDesRaw adopts them.
  fileId       String?
  refDesRaw    String? // raw refdes cell from the BOM, e.g. "R1, R2, R3"
  description  String?
  manufacturer String?
  mpn          String? // manufacturer part number
  value        String?
  footprint    String?
  quantity     Int     @default(1)

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file       ProjectFile? @relation(fields: [fileId], references: [id], onDelete: Cascade)
  components Component[]  // many-to-many

  @@index([projectId])
  @@index([fileId])
}

/// A chunk of a document, ready for future RAG embedding/retrieval.
model DocumentChunk {
  id         String  @id @default(cuid())
  projectId  String
  fileId     String?
  chunkIndex Int     @default(0)
  // 1-based page number in the source document (PDFs); null when the source
  // has no page structure. Enables "cite file + page" grounding.
  page       Int?
  content    String
  // Embedding stored as JSON string for Phase 1 portability. In Postgres this
  // becomes a pgvector column later.
  embedding  String?
  metadata   String? // JSON string for arbitrary chunk metadata

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    ProjectFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([fileId])
}

/// One execution of the AI design-review pipeline over a project's parsed data.
/// Findings are persisted so past reviews remain viewable (and, later, resumable).
model ReviewRun {
  id        String   @id @default(cuid())
  projectId String
  // Lifecycle: "running" | "completed" | "failed". One live "running" row per
  // project (enforced in review-service); stale running rows are reaped as
  // failed on the next start attempt.
  status    String   @default("completed")
  model     String // LLM model id used, e.g. "claude-sonnet-4-6"
  summary   String? // short natural-language overview produced by the reviewer
  error     String? // populated when status = "failed"
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  findings Finding[]

  @@index([projectId])
}

/// Global datasheet document library. A datasheet is a fact about a part, not a
/// project: tier-2/3 documents are stored once per (mpn, contentHash) and linked
/// into projects as ProjectFile rows pointing at the same stored file, so the
/// same LM317 PDF is fetched and stored once for the whole installation.
model DatasheetLibrary {
  id          String   @id @default(cuid())
  mpn         String
  contentHash String   @unique // sha256 of file bytes
  filePath    String // path relative to the uploads root (shared "library" dir)
  sourceUrl   String?
  fetchedAt   DateTime @default(now())

  @@index([mpn])
}

/// Local log of document searches (EMBEDDINGS_FOR_RAG.md W1 feedback loop).
/// Rows with hits = 0 are real vocabulary gaps; a later successful query in
/// the same project shows the rephrasing that worked. Feeds the synonym table
/// (retrieval-synonyms.ts) and the retrieval eval set. Local-only, best-effort
/// (a failed write never fails a search).
model RetrievalLog {
  id        String   @id @default(cuid())
  projectId String
  query     String
  // Which match strategy produced the outcome: "strict" | "relaxed" | "synonyms"
  strategy  String
  hits      Int
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

/// App-wide key-value settings (single-user desktop app, so no per-user rows).
/// Values are JSON-encoded; typed access goes through
/// src/server/services/settings-service.ts, which owns keys and defaults.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Global per-MPN datasheet cache. Keyed by MPN only — shared across all projects
/// so the same part is never fetched or re-parsed twice.
model MpnCache {
  id           String    @id @default(cuid())
  mpn          String    @unique
  // Lifecycle: "pending" | "complete" | "missing_datasheet" | "error"
  status       String    @default("pending")
  datasheetUrl String?
  // JSON string: { maxVoltageV, maxCurrentA, tempRangeMinC, tempRangeMaxC, componentType, notes }
  specs        String?
  error        String?
  fetchedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([mpn])
}

/// A single design-review finding. Mirrors the action-item format: what to look
/// at, why it's flagged, severity, and whether a human HW review is required.
model Finding {
  id          String  @id @default(cuid())
  reviewRunId String
  block       String // functional block, e.g. "LO Synthesizer", "LNA Chain"
  // Severity: "possible_bug" | "verify" | "watch" | "minor" | "cosmetic" | "ok"
  severity    String
  title       String // short "what to look at"
  rationale   String // "why it's flagged" — quantitative where possible
  refDes      String // comma-separated refdes list, e.g. "U7, R12" (SQLite has no arrays)
  // true = needs a human hardware review (the doc's "yellow"); false = informational.
  hwReviewRequired Boolean @default(false)

  reviewRun ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
}
